APP_NAME="A2A-CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=a2a_crm
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# A2A ERP Integration
A2A_ERP_BASE_URL=
A2A_ERP_API_KEY=
A2A_ERP_TIMEOUT=10

# Anthropic AI (Claude API) — always dispatch via job, never call synchronously in web request
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# CRM Application Settings
CRM_CONSENT_FORM_VERSION=1.0

# CRM Payments (BRD: CRM-FM-001 to CRM-FM-013) — DUMMY values; replace before go-live
CRM_PAYMENTS_DEFAULT_GATEWAY=razorpay
CRM_PAYMENTS_CURRENCY=INR
CRM_PAYMENTS_LINK_TTL_MINUTES=4320

# Razorpay
RAZORPAY_KEY_ID=rzp_test_DUMMY_KEY_ID
RAZORPAY_KEY_SECRET=DUMMY_KEY_SECRET_REPLACE_ME
RAZORPAY_WEBHOOK_SECRET=DUMMY_WEBHOOK_SECRET_REPLACE_ME
RAZORPAY_BASE_URL=https://api.razorpay.com/v1

# PayU (adapter is a stub; do not enable in prod yet)
PAYU_MERCHANT_KEY=DUMMY_PAYU_KEY
PAYU_MERCHANT_SALT=DUMMY_PAYU_SALT
PAYU_WEBHOOK_SECRET=DUMMY_PAYU_WEBHOOK_SECRET
PAYU_BASE_URL=https://test.payu.in

# CCAvenue (adapter is a stub; do not enable in prod yet)
CCAVENUE_MERCHANT_ID=DUMMY_CCA_MID
CCAVENUE_ACCESS_CODE=DUMMY_CCA_ACCESS_CODE
CCAVENUE_WORKING_KEY=DUMMY_CCA_WORKING_KEY
CCAVENUE_BASE_URL=https://test.ccavenue.com

VITE_APP_NAME="${APP_NAME}"
